[gd_scene format=3 uid="uid://blen6hpoa4nv8"]

[sub_resource type="GDScript" id="GDScript_wusub"]
script/source = "extends Label

@onready var start_y = position.y

func _ready() -> void:
	_update_display(Global.money)
	Global.money_changed.connect(_update_display)

func _update_display(amount: int) -> void:
	text = \"Bits: %d\" % amount

func _process(_delta: float) -> void:
	position.y = start_y + sin(Time.get_ticks_msec() * 0.005) *  5.0
"

[sub_resource type="GDScript" id="GDScript_3iaii"]
resource_name = "BuyKeycap"
script/source = "extends Button

func _ready():
	_update_button()
	Global.money_changed.connect(func(_amt): _update_button())
	
	
func _pressed():
	if Global.money >= Global.next_key_cost:
		Global.buy_key()
	else:
		var tween = create_tween()
		tween.tween_property(self, \"modulate\", Color.RED, 0.1)
		tween.tween_property(self, \"modulate\", Color.WHITE, 0.1)
		
func _update_button():
	text = \"Buy Key: $\" + str(Global.next_key_cost)
	disabled = Global.money < Global.next_key_cost
"

